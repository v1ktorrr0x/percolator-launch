# ── Helius RPC (PERC-469: all keys server-side; never use NEXT_PUBLIC_ for RPC) ──
# Generic fallback key used by /api/rpc proxy when network-specific keys are absent
HELIUS_API_KEY=
# Optional: network-specific keys — preferred over HELIUS_API_KEY when set
# Allows different rate-limit tiers per network without touching the generic key
HELIUS_MAINNET_API_KEY=
HELIUS_DEVNET_API_KEY=
# Optional: dedicated key for WebSocket subscriptions only (safe to expose client-side)
# Set to a restricted Helius key that only allows WSS connections.
NEXT_PUBLIC_HELIUS_WS_API_KEY=
# Optional: full server-side RPC URL override (bypasses key-based URL building)
NEXT_PUBLIC_HELIUS_RPC_URL=

# Solana RPC URL (server-side, optional override)
SOLANA_RPC_URL=

# API authentication token for POST routes (optional, skipped if empty)
API_AUTH_TOKEN=

# ── Internal API Security ──
# INTERNAL_API_SECRET: guards cross-network routing on /api/rpc (PERC-8310).
# Required in production — if unset, all ?network= overrides are blocked (safe default).
# Must be set for any internal service (e.g. Privy dual-chain config) that needs
# to route to a different network than the deployment default.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Solana network (devnet | mainnet)
NEXT_PUBLIC_DEFAULT_NETWORK=devnet

# Crank keypair (base58-encoded secret key)
CRANK_KEYPAIR=

# Program ID override (optional)
NEXT_PUBLIC_PROGRAM_ID=
PROGRAM_ID=

# Indexer API key (for prices/trades/stats endpoints)
INDEXER_API_KEY=

# Devnet mint authority keypair — JSON array of 64 bytes — KEEP SECRET, never commit
# Required for: /api/faucet, /api/auto-fund, /api/airdrop, /api/devnet-mint-token,
#               /api/devnet-pre-fund, /api/devnet-mirror-mint
# Generate: solana-keygen new --no-bip39-passphrase --outfile /tmp/mint-auth.json && cat /tmp/mint-auth.json
DEVNET_MINT_AUTHORITY_KEYPAIR=


# ── Sentry Error Tracking ──
# Frontend DSN (client-side, safe to expose)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (can be same as above or separate)
SENTRY_DSN=
# Auth token for source map uploads (CI/CD only, NEVER commit)
# Generate at: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
# Sentry org and project slugs
SENTRY_ORG=percolator
SENTRY_PROJECT=percolator-app

# ── Internal Service URLs (server-side only) ──
# Oracle Keeper service URL — used by /api/oracle-keeper/register to forward keeper registrations
# Default: http://localhost:8081 (dev). MUST be set in production to point to the keeper container.
KEEPER_INTERNAL_URL=

# Oracle Bridge service URL — used by /api/oracle/publishers to read publisher list
# Default: http://127.0.0.1:18802 (dev). MUST be set in production to point to the bridge service.
ORACLE_BRIDGE_URL=

# ── Waitlist (separate Supabase project from trading data) ──────────────────
# Schema: ./supabase-waitlist-schema.sql (run on the waitlist Supabase project)
# Set on Vercel project (Production + Preview).
NEXT_PUBLIC_WAITLIST_SUPABASE_URL=
NEXT_PUBLIC_WAITLIST_SUPABASE_KEY=
