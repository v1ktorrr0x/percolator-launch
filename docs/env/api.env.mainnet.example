# =============================================================================
# Percolator API — Mainnet Environment Variables
# =============================================================================
# Railway service: percolator-api-mainnet
# Copy this file, fill in values, then set via Railway CLI or dashboard.
# DO NOT commit filled-in values to git.
# =============================================================================

# --- Server ---
NODE_ENV=production
API_PORT=4000
API_VERSION=v1

# Production CORS: exact origins only, no wildcards.
CORS_ORIGINS=https://percolatorlaunch.com,https://www.percolatorlaunch.com
TRUSTED_PROXY_DEPTH=1
# Enforce mainnet — rejects devnet connections
FORCE_MAINNET=1

# --- Authentication ---
# Generate: openssl rand -hex 32
API_AUTH_KEY=<GENERATE_ME>

# --- WebSocket ---
MAX_WS_CONNECTIONS=1000
MAX_UNAUTH_WS_CONNECTIONS_PER_IP=5
WS_AUTH_REQUIRED=true
# Generate: openssl rand -hex 32
WS_AUTH_SECRET=<GENERATE_ME>

# --- Solana ---
# Helius mainnet RPC (paid plan)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<HELIUS_MAINNET_API_KEY>

# Program ID — mainnet deployment
PROGRAM_ID=ESa89R5Es3rJ5mnwGybVRG1GrNt9etP11Z5V2QWD4edv

# Network
NETWORK=mainnet

# --- Supabase ---
SUPABASE_URL=<SUPABASE_PROJECT_URL>
# CRITICAL: use the ROTATED service_role key (not the one leaked in git history)
SUPABASE_SERVICE_KEY=<ROTATED_SUPABASE_SERVICE_ROLE_KEY>

# --- Upstash Redis (rate limiting — required for multi-replica) ---
UPSTASH_REDIS_REST_URL=<UPSTASH_URL>
UPSTASH_REDIS_REST_TOKEN=<UPSTASH_TOKEN>

# --- Sentry (error tracking) ---
SENTRY_DSN=https://9d5b46f4539d8868d6afe92dee953ba3@o4510225747738624.ingest.de.sentry.io/4510899260293200
SENTRY_ENVIRONMENT=production

# --- Internal API (keeper ↔ api communication) ---
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=<GENERATE_ME>
