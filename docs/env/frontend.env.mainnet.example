# =============================================================================
# Percolator Frontend (Next.js) — Mainnet Environment Variables
# =============================================================================
# Deployed to Vercel. Set these in Vercel dashboard → Settings → Environment Variables.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# DO NOT commit filled-in values to git.
# =============================================================================

# --- Network ---
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_DEFAULT_NETWORK=mainnet
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# --- Program ---
NEXT_PUBLIC_PROGRAM_ID=ESa89R5Es3rJ5mnwGybVRG1GrNt9etP11Z5V2QWD4edv

# --- API ---
NEXT_PUBLIC_API_URL=https://api.percolatorlaunch.com
NEXT_PUBLIC_WS_URL=wss://api.percolatorlaunch.com

# --- Solana RPC (browser) ---
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<HELIUS_MAINNET_API_KEY>
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<HELIUS_MAINNET_API_KEY>
NEXT_PUBLIC_HELIUS_API_KEY=<HELIUS_MAINNET_API_KEY>

# --- Supabase (browser — anon key only) ---
NEXT_PUBLIC_SUPABASE_URL=<SUPABASE_PROJECT_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>

# --- Privy Wallet ---
NEXT_PUBLIC_PRIVY_APP_ID=<PRIVY_APP_ID>

# --- WalletConnect ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<WALLETCONNECT_PROJECT_ID>

# --- Sentry (frontend) ---
NEXT_PUBLIC_SENTRY_DSN=https://c9e7d3b3289cc324935e3ca341b00d00@o4510225747738624.ingest.de.sentry.io/4510899224510544
SENTRY_AUTH_TOKEN=<SENTRY_AUTH_TOKEN>
SENTRY_ORG=dcc-pz
SENTRY_PROJECT=percolator-frontend
